#Camera inside sphere:   (camera at sphere center)
# C 0,0,0 0,0,1 45
A 0.2 255,255,255

#Zero/near-zero direction: (zero direction vector)
C 25,0,0 1,0,0 180

#Extreme FOV: 
# C 0,0,5 0,0,-1 0
# or 180 (min/max FOV)

#Light inside sphere: 
# L 0,0,0 0.5 255,255,255
L 20,0,100 0.5 255,255,255

#Negative/tiny dimensions:
sp 20,0,0 16 255,0,0
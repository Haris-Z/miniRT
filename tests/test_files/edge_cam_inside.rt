#Camera inside sphere:   (camera at sphere center)
# C 0,0,0 0,0,1 45
A 0.2 255,255,255

#Zero/near-zero direction: (zero direction vector)
C 0,0,0 0,0,1 45

#Extreme FOV: 
# C 0,0,5 0,0,-1 0
# or 180 (min/max FOV)

#Light inside sphere: 
# L 0,0,0 0.5 255,255,255
L 0,0,20 0.5 255,255,255

#Negative/tiny dimensions:
sp 0,0,30 4.3 255,0,0
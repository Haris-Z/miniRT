# artistic.rt - A colorful sphere composition

# Lighting and Camera
A 0.2 255,255,255
C 0,0,-30 0,0,1 80
L 20,20,20 0.8 255,0,0
#L -20,-20,10 0.3 255,255,200

# ========================
# MAIN COMPOSITION
# ========================

# Central feature: Gradient rainbow sphere cluster
sp 0,0,30 8.0 255,50,50
sp 5,0,32 3.5 255,150,50
sp -5,0,32 3.5 255,255,50
sp 0,5,32 3.5 50,255,50
sp 0,-5,32 3.5 50,150,255
sp 7,7,35 2.8 100,50,255
sp -7,-7,35 2.8 255,50,200

# Left side: Cool color progression
sp -25,0,40 6.0 50,100,255
sp -30,8,42 4.0 50,200,255
sp -30,-8,42 4.0 100,255,200
sp -35,15,45 2.5 150,255,255
sp -35,-15,45 2.5 200,255,255

# Right side: Warm color progression
sp 25,0,40 6.0 255,100,50
sp 30,8,42 4.0 255,150,50
sp 30,-8,42 4.0 255,200,50
sp 35,15,45 2.5 255,220,100
sp 35,-15,45 2.5 255,180,100

# Background layer: Large, subtle colored spheres
sp -15,25,55 10.0 100,200,255
sp 15,-25,55 10.0 255,200,100
sp 0,30,60 12.0 200,255,200
sp 0,-30,60 12.0 255,200,255

# Middle ground: Medium spheres with transparency effect (via size)
sp -20,-20,35 7.0 255,100,150
sp 20,20,35 7.0 150,200,255
sp -10,20,38 5.5 200,255,150
sp 10,-20,38 5.5 255,150,255

# Floating small spheres (creating depth)
sp -5,15,50 2.0 255,255,100
sp 5,-15,50 2.0 100,255,255
sp 12,10,48 2.5 255,100,100
sp -12,-10,48 2.5 100,100,255

# Top cluster
sp 0,40,45 8.0 255,150,200
sp 8,35,47 4.0 200,150,255
sp -8,35,47 4.0 150,255,150

# Bottom cluster
sp 0,-40,45 8.0 150,200,255
sp 8,-35,47 4.0 255,200,150
sp -8,-35,47 4.0 200,255,200

# ========================
# FOREGROUND ELEMENTS
# ========================

# Small decorative spheres in front
sp -15,0,20 3.0 255,255,0
sp 15,0,20 3.0 0,255,255
sp 0,15,22 3.0 255,0,255
sp 0,-15,22 3.0 0,255,0

# Tiny accent spheres
sp 25,25,25 1.5 255,255,255
sp -25,-25,25 1.5 255,255,255
sp 25,-25,27 1.5 255,200,200
sp -25,25,27 1.5 200,200,255

# ========================
# PATTERN ELEMENTS
# ========================

# Circular pattern of small spheres
# (12 positions around a circle, radius 18)
sp 18,0,40 1.8 255,100,100
sp 13.5,13.5,40 1.8 255,200,100
sp 0,18,40 1.8 100,255,100
sp -13.5,13.5,40 1.8 100,200,255
sp -18,0,40 1.8 200,100,255
sp -13.5,-13.5,40 1.8 255,100,200
sp 0,-18,40 1.8 200,255,100
sp 13.5,-13.5,40 1.8 100,255,200

# Second circular pattern (slightly larger, different Z)
sp 0,25,35 2.2 255,150,0
sp 17.7,17.7,35 2.2 0,255,150
sp 25,0,35 2.2 150,0,255
sp 17.7,-17.7,35 2.2 255,0,150
sp 0,-25,35 2.2 0,150,255
sp -17.7,-17.7,35 2.2 150,255,0
sp -25,0,35 2.2 255,150,150
sp -17.7,17.7,35 2.2 150,150,255

# ========================
# FINAL ACCENTS
# ========================

# A few extra-large background spheres for scale
sp 40,40,80 15.0 100,150,200
sp -40,-40,80 15.0 200,150,100

# Some medium foreground spheres
sp 30,5,25 4.5 255,100,0
sp -30,5,25 4.5 0,100,255
sp 5,30,28 4.5 100,255,0
sp 5,-30,28 4.5 255,0,100

# Total spheres: 58
# A dark ground and a back wall.
# Two tall stone pillars left/right with round caps.
# A central blue “planet” on a pedestal.
# A gold ring around the planet made from little spheres.
# Some foreground stones so the scene has depth.
A 0.155 255,255,255
C -10,0,4 1,0,0 90
L 18,-10,18 0.85 255,255,240

# ground + backwall
# Ground: z = -2
# pl 0,0,-2 0,0,1 50,55,60
# Wall: x = 38 (facing camera)
pl 38,0,0 -1,0,0 28,30,34

# pl 0,5,-1.995 0,0,1 70,70,75
# pl 0,-5,-1.995 0,0,1 70,70,75

# acne
pl 0,0,-2 0,0,1 50,55,60
pl 0,5,-1.995 0,0,1 70,70,75
pl 0,-5,-1.995 0,0,1 70,70,75

# left/right pillars/pedestals
cy 16,7,2 0,0,1 1.3 8 180,180,190
cy 16,-7,2  0,0,1 1.3 8 180,180,190

# pillar tops
sp 16,-7,6 1.6 220,220,230
sp 16,7,6  1.6 220,220,230

# vertical pedestal
cy 26,0,-0.5 0,0,1 2.2 3 90,90,100
# sphere on cylinder / pedestal
sp 26,0,3.0 3.2 70,120,255

# sphere ring
sp 26,5.2,3.0 0.55 240,220,120
sp 26,4.3,4.1 0.55 240,220,120
sp 26,2.6,4.9 0.55 240,220,120
sp 26,0.0,5.2 0.55 240,220,120
sp 26,-2.6,4.9 0.55 240,220,120
sp 26,-4.3,4.1 0.55 240,220,120
sp 26,-5.2,3.0 0.55 240,220,120
sp 26,-4.3,1.9 0.55 240,220,120
sp 26,-2.6,1.1 0.55 240,220,120
sp 26,0.0,0.8 0.55 240,220,120
sp 26,2.6,1.1 0.55 240,220,120
sp 26,4.3,1.9 0.55 240,220,120

# spheres in fore ground
sp 10,-3,-1.2 1.2 160,90,70
sp 12,2,-1.3  1.0 140,80,65
sp 8,4,-1.25  0.9 155,85,70

# small spheres close to sculpture
sp 22,-5,-1.2 0.9 120,170,140
sp 22,5,-1.2  0.9 120,170,140
sp 30,-6,-1.2 0.8 200,110,120
sp 30,6,-1.2  0.8 200,110,120
